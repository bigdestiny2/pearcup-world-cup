# dependencies (root tooling + app self-contained install)
node_modules/

# local runtime config (may hold API keys / SDK paths) — only the .example is tracked
config/pearcup.runtime.json
**/config/pearcup.runtime.json

# local release handoff artifacts (exact bundles/receipts are regenerated by scripts)
.pearcup-release/

# Generated Cloudflare Pages upload artifact. Source lives in site/ and app/.
cloudflare/pages-dist/

# generated reports and machine-local editor/agent settings
outputs/
.claude/
.codex/

# os / misc
.DS_Store
*.log
