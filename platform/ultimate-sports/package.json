{
  "name": "ultimate-sports",
  "version": "0.4.0",
  "description": "Ultimate Sports — P2P tournament client: lobby, per-sport shell, and real-time peer matches for Pear.",
  "type": "commonjs",
  "main": "index.cjs",
  "license": "MIT",
  "pear": {
    "name": "ultimate-sports",
    "gui": {
      "main": "lobby-app/index.html",
      "width": 1360,
      "height": 900,
      "minWidth": 1024,
      "minHeight": 760,
      "backgroundColor": "#0f172a"
    },
    "routes": {
      "": ".",
      "/": "."
    },
    "assets": {
      "ui": {
        "link": "pear://0.940.cktxzetiwt6un3ado5kgqedge6ya4nfazjckzq76zcapefwxakdy",
        "name": "Pear Runtime",
        "only": [
          "/boot.bundle",
          "/by-arch/%%HOST%%",
          "/prebuilds/%%HOST%%"
        ]
      }
    },
    "stage": {
      "include": [
        "/index.cjs",
        "/package.json",
        "/lobby-app",
        "/shell",
        "/shell/engines.bundle.js",
        "/generated-assets"
      ],
      "ignore": [
        "/.git",
        "/docs",
        "/src",
        "/test",
        "/scripts",
        "/generated-assets/_asset-manifest.json",
        "/generated-assets/_generation-plan.json",
        "/generated-reports",
        "/mma-app",
        "/app",
        "/*.mjs",
        "/*.test.js",
        "/shell/*.mjs",
        "/shell/*.test.js"
      ],
      "entrypoints": [
        "/shell/peer-net.js",
        "/shell/runtime-settings.js",
        "/lobby-app/crypto-identity.js",
        "/lobby-app/app.js"
      ]
    }
  },
  "scripts": {
    "dev": "node scripts/run-pear-dev.mjs",
    "dev:devtools": "node scripts/run-pear-dev.mjs --devtools",
    "stage": "pear stage ultimate-sports-dev .",
    "release": "pear release ultimate-sports-dev .",
    "release:prepare": "node scripts/prepare-ultimate-sports-release.mjs",
    "release:stage": "node scripts/prepare-ultimate-sports-release.mjs --stage",
    "release:publish": "node scripts/prepare-ultimate-sports-release.mjs --release",
    "smoke:fits": "node scripts/smoke-ultimate-fits.mjs",
    "test": "node --test test/*.test.js",
    "build:engines": "node scripts/build-engines.mjs",
    "preview": "node scripts/serve-app.js --port 4197"
  },
  "dependencies": {
    "b4a": "^1.6.0",
    "hypercore-crypto": "^3.0.0",
    "hyperswarm": "^4.0.0",
    "pear-bridge": "^1.2.5",
    "pear-electron": "^1.7.28"
  },
  "optionalDependencies": {
    "@qvac/sdk": "^0.14.0",
    "@tetherto/wdk": "^1.0.0-beta.12",
    "@tetherto/wdk-wallet-btc": "^1.0.0-beta.10",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.14",
    "qrcode-generator": "^2.0.4"
  }
}
